# =============================================================================
# THIRAMAI Genesis — staging environment template
# =============================================================================
# Copy to `.env.staging`, replace secrets, and deploy with staging-specific infra.
# Never commit `.env.staging` with real secrets.
# =============================================================================

# --- Runtime mode ---
ENV=staging
THIRAMAI_ENV=staging
ENVIRONMENT=staging

# --- Resource tuning ---
WEB_PORT=18000
GUNICORN_WORKERS=2
THIRAMAI_WORKER_POLL_SEC=2
THIRAMAI_ALERT_INTERVAL_MINUTES=15

# --- PostgreSQL (staging DB) ---
POSTGRES_USER=thiramai_staging
POSTGRES_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD
POSTGRES_DB=thiramai_staging

# SQLAlchemy URL inside Docker network (host `db` = Postgres service)
DATABASE_URL=postgresql+psycopg2://thiramai_staging:CHANGE_ME_STAGING_DB_PASSWORD@db:5432/thiramai_staging

# --- JWT / auth ---
SECRET_KEY=CHANGE_ME_STAGING_SECRET_KEY_MINIMUM_32_RANDOM_BYTES
ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- AI providers ---
GROQ_API_KEY=staging_groq_api_key
TAVILY_API_KEY=staging_tavily_api_key
# GROQ_AGENT_MODEL=llama-3.3-70b-versatile

# --- Google Calendar (optional) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://staging.thiramai.co.in/auth/google/callback
# THIRAMAI_INTEGRATION_FERNET_KEY=

# --- HTTP / CORS (staging origins) ---
THIRAMAI_CORS_ORIGINS=https://staging-app.yourdomain.com,https://staging.yourdomain.com

# --- Security ---
THIRAMAI_SAFE_ERRORS=1
THIRAMAI_RL_TRUST_X_FORWARDED_FOR=1
THIRAMAI_TRUSTED_PROXY_IPS=
THIRAMAI_PROXY_TRUSTED_HOSTS=*
# THIRAMAI_ALLOWED_HOSTS=staging-app.yourdomain.com,staging.yourdomain.com,127.0.0.1,localhost
# THIRAMAI_LEGACY_ROOT_SPA=1
# THIRAMAI_COMMAND_CENTER_BUILD_ID=
THIRAMAI_LOG_JSON=1
# THIRAMAI_HEALTH_REQUIRE_AI=0
# THIRAMAI_STRICT_ORIGIN=0

# --- Rate limits ---
THIRAMAI_RL_AUTH_PER_MINUTE=20
THIRAMAI_RL_CHAT_PER_MINUTE=40
THIRAMAI_RL_CHAT_QUERY_PER_USER_PER_MINUTE=30

# --- Dev bypass (keep disabled) ---
THIRAMAI_AUTH_DISABLED=0

# --- Alerts ---
THIRAMAI_ENABLE_ALERT_SCHEDULER=1
THIRAMAI_ALERT_LOW_STOCK_THRESHOLD=10

# --- Personal OS weather ---
# PERSONAL_OS_WEATHER_LAT=12.97
# PERSONAL_OS_WEATHER_LON=77.59

# --- Autonomous AI ---
# THIRAMAI_ENABLE_AUTONOMY_ENGINE=1
# THIRAMAI_AUTONOMY_INTERVAL_MINUTES=15

# --- Redis (staging Redis) ---
REDIS_URL=redis://redis:6379/1

# --- Web Push (VAPID) ---
# THIRAMAI_VAPID_PUBLIC_KEY=
# THIRAMAI_VAPID_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# THIRAMAI_VAPID_SUBJECT=mailto:staging-ops@yourdomain.com
# THIRAMAI_PUSH_DAILY_BRIEF_HOUR_UTC=2

# --- Gunicorn ---
# GUNICORN_WORKERS: set in Resource tuning above

# --- PostgreSQL job queue ---
THIRAMAI_JOB_QUEUE=db
# THIRAMAI_WORKER_POLL_SEC: set in Resource tuning above

# --- Retail / GST (optional) ---
# THIRAMAI_AUTO_EXECUTE_SELL_STOCK=1
# THIRAMAI_RETAIL_SALE_ROLES=admin,staff
# THIRAMAI_RETAIL_GST_IGST=0

# --- HITL / billing ---
SOVEREIGN_BYPASS_HITL=0
