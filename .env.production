# === DATABASE CONFIGURATION ===
#
# Single shared password for both Postgres roles (admin + app) to keep the four
# references below in lockstep. Two roles, one password is acceptable for a
# pilot deployment; for a regulated multi-tenant SaaS launch, split them and
# rotate via the secrets manager (see docs/operations/secrets-management.md).
#
# Required invariants:
#   - DATABASE_URL password   == THIRAMAI_APP_DB_PASSWORD   (app role)
#   - ADMIN_DATABASE_URL pwd  == POSTGRES_PASSWORD          (admin role)

POSTGRES_USER=thiramai
POSTGRES_PASSWORD=thiramai_2026
POSTGRES_DB=thiramai

# Alembic uses this URL via alembic/env.py (prefers ADMIN_DATABASE_URL over DATABASE_URL).
ADMIN_DATABASE_URL=postgresql+psycopg2://thiramai:thiramai_2026@db:5432/thiramai

# Application role (created by migration 0079_create_app_role_fix_rls) - NOSUPERUSER
# NOBYPASSRLS. Web/worker connections use this URL so RLS is genuinely enforced.
# IMPORTANT: App connects as thiramai_app, NOT thiramai.
DATABASE_URL=postgresql+psycopg2://thiramai_app:thiramai_2026@db:5432/thiramai

# Initial password applied to the thiramai_app role by migration 0079 and scripts/init-db.sh.
# MUST equal the password embedded in DATABASE_URL above.
THIRAMAI_APP_DB_PASSWORD=thiramai_2026

REDIS_URL=redis://redis:6379/0
SECRET_KEY=31I-zNYnWHN0gKKqf-GVRDthqLmonoRjBtW4OcDzbNmgytWZ_XC8lx5j2eXh_afK
THIRAMAI_CORS_ORIGINS=https://app.thiramai.co.in,https://thiramai.co.in

# JWT alias (core/auth.py)
JWT_SECRET_KEY=31I-zNYnWHN0gKKqf-GVRDthqLmonoRjBtW4OcDzbNmgytWZ_XC8lx5j2eXh_afK

# === AI API KEYS (replace placeholders with real keys from https://console.groq.com/ and https://tavily.com/) ===
GROQ_API_KEY=placeholder_groq_key_for_testing
TAVILY_API_KEY=placeholder_tavily_key_for_testing
# OPENAI_API_KEY=

WEB_PORT=8000
GUNICORN_WORKERS=4
THIRAMAI_SAFE_ERRORS=1
THIRAMAI_RL_TRUST_X_FORWARDED_FOR=1
# Trusted proxy allowlist: [] or JSON array or comma-separated CIDRs (empty env breaks list parsing in settings)
THIRAMAI_TRUSTED_PROXY_IPS=[]
THIRAMAI_LOG_JSON=1
THIRAMAI_ENFORCE_SECURE_COOKIES=1
THIRAMAI_RLS_BYPASS=0

POOL_SIZE=20
MAX_OVERFLOW=40
POOL_TIMEOUT=30
POOL_RECYCLE=3600
POOL_PRE_PING=true

THIRAMAI_DECISION_AB_TEST=false
DECISION_AB_TEST=false
THIRAMAI_POLICY_ENGINE_PCT=100
POLICY_ENGINE_PCT=100
POLICY_ENGINE_PERCENTAGE=100
THIRAMAI_POLICY_SAFE_FALLBACK=true
THIRAMAI_DISABLE_LEGACY_FALLBACK=false
DISABLE_LEGACY_FALLBACK=false
THIRAMAI_HEALTH_REQUIRE_POLICY_ENGINE=1
THIRAMAI_AI_QUALITY_TRACKING=1
THIRAMAI_AI_QUALITY_WINDOW=1000
THIRAMAI_AI_QUALITY_MIN_BASELINE=100
THIRAMAI_AI_QUALITY_DRIFT_DELTA=0.2
THIRAMAI_POLICY_CB_FAILURE_THRESHOLD=5
THIRAMAI_POLICY_CB_SUCCESS_THRESHOLD=2
THIRAMAI_POLICY_CB_TIMEOUT_SECONDS=60

# --- Health Check Configuration (Production Mode — see docs/deployment/HEALTH_CHECKS.md, PRODUCTION_MODE.md) ---
# Alembic check enabled with ignore mismatch (DB can be ahead of expected)
THIRAMAI_SKIP_ALEMBIC_CHECK=0
THIRAMAI_EXPECTED_DB_REVISION=0079_create_app_role_fix_rls
THIRAMAI_HEALTH_IGNORE_ALEMBIC_MISMATCH=1

# Optional components don't fail readiness
THIRAMAI_HEALTH_REQUIRE_AI=0
THIRAMAI_HEALTH_STRICT_MODE=0
THIRAMAI_HEALTH_REQUIRE_GOAL_SQLITE=0

# Production settings
THIRAMAI_JOB_SQLITE=0
THIRAMAI_ENV=production
ENV=production

THIRAMAI_JOB_QUEUE=db
