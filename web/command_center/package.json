{
  "name": "thiramai-command-center",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx}\" --fix",
    "build": "npm run lint && vite build && npm run build:validate",
    "build:validate": "node scripts/validate-build.mjs",
    "build:vite-only": "vite build",
    "deploy:safe": "powershell -ExecutionPolicy Bypass -File scripts/deploy-command-center.ps1",
    "dev": "vite --host 127.0.0.1 --port 5173"
  },
  "dependencies": {
    "@sentry/react": "^8.55.1",
    "@sentry/vite-plugin": "^5.2.0",
    "axios": "^1.7.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.10",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.4",
    "vite": "^5.4.11"
  }
}
