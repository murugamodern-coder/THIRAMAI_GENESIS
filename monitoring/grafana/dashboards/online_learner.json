{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "uid": "thiramai-online-learner",
  "title": "Thiramai - Online Learner",
  "tags": ["thiramai", "online-learner", "ml"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "templating": {"list": []},
  "links": [
    {"title": "World Model", "type": "link", "url": "/d/thiramai-world-model"},
    {"title": "Overview", "type": "link", "url": "/d/thiramai-overview"}
  ],
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Rolling Accuracy",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "thiramai_online_learner_accuracy", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 0.7}]}}, "overrides": []}
    },
    {
      "id": 2, "type": "stat", "title": "Drift Score (KMeans inertia)",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "thiramai_online_learner_drift_score", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]}}, "overrides": []}
    },
    {
      "id": 3, "type": "stat", "title": "Samples Seen (24h)",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "increase(thiramai_online_learner_samples_total[24h])", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 4, "type": "stat", "title": "Retrains (7d)",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "increase(thiramai_online_learner_retrains_total[7d])", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 5, "type": "timeseries", "title": "Accuracy over Time",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "thiramai_online_learner_accuracy", "refId": "A", "legendFormat": "accuracy"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []}
    },
    {
      "id": 6, "type": "timeseries", "title": "Drift Score Trend",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "thiramai_online_learner_drift_score", "refId": "A", "legendFormat": "drift"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 7, "type": "timeseries", "title": "Samples / Retrains Rate",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [
        {"expr": "rate(thiramai_online_learner_samples_total[5m]) * 60", "refId": "A", "legendFormat": "samples/min"},
        {"expr": "rate(thiramai_online_learner_retrains_total[1h]) * 3600", "refId": "B", "legendFormat": "retrains/hr"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    }
  ]
}
