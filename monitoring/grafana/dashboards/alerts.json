{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "uid": "thiramai-alerts",
  "title": "Thiramai - Alerts and SLO",
  "tags": ["thiramai", "alerts", "slo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {"list": []},
  "links": [
    {"title": "Overview", "type": "link", "url": "/d/thiramai-overview"},
    {"title": "Trading", "type": "link", "url": "/d/thiramai-trading"},
    {"title": "Broker", "type": "link", "url": "/d/thiramai-broker"}
  ],
  "panels": [
    {
      "id": 1, "type": "stat", "title": "5xx Error Rate (per min)",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(thiramai_api_error_total{status_code=~\"5..\"}[5m]) * 60)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]}}, "overrides": []}
    },
    {
      "id": 2, "type": "stat", "title": "Decision Errors (per min)",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "sum(rate(thiramai_decision_error_total[5m]) * 60)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 3, "type": "stat", "title": "Kill-switches Active",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "sum(thiramai_trade_kill_switch_active)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 4, "type": "stat", "title": "p99 Latency Budget Burn",
      "description": "Alerts when p99 API latency > 1000 ms.",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.99, sum(rate(thiramai_api_request_latency_ms_bucket[5m])) by (le))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ms", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 500}, {"color": "red", "value": 1000}]}}, "overrides": []}
    },
    {
      "id": 5, "type": "timeseries", "title": "Error Rate by Status Code",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "sum by (status_code) (rate(thiramai_api_error_total[5m]) * 60)", "refId": "A", "legendFormat": "{{status_code}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 6, "type": "timeseries", "title": "Redis + Broker Errors",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "sum(rate(thiramai_redis_connection_errors_total[5m]) * 60)", "refId": "A", "legendFormat": "redis"},
        {"expr": "sum(rate(thiramai_trade_broker_errors_total[5m]) * 60)", "refId": "B", "legendFormat": "broker"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 7, "type": "timeseries", "title": "Daily Loss Limit Breaches (kill-switch firings)",
      "datasource": {"type": "prometheus", "uid": "PROMETHEUS_DS_UID"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [{"expr": "thiramai_trade_kill_switch_active", "refId": "A", "legendFormat": "user {{user_id}}"}],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 1}, "overrides": []}
    }
  ]
}
