# =============================================================================
# THIRAMAI Genesis — production environment template (Phase 5)
# =============================================================================
# On the server: copy to `.env.production`, replace every CHANGE_ME and secret, then run ONE of:
#
#   **SaaS production (recommended):** Postgres + Redis + Gunicorn API + job worker + alert worker
#   docker compose -f docker-compose.production.yml --env-file .env.production up -d --build
#
#   **Minimal:** API + Postgres only (alerts inside web — no Redis / job worker)
#   docker compose -f docker-compose.prod-slim.yml --env-file .env.production up -d --build
#
#   **Dev / full stack on LAN:** `docker-compose.yml` (published DB/Redis ports + worker-jobs)
#
# Never commit `.env.production` with real secrets.
# =============================================================================

# --- Runtime mode (required for production CORS / OpenAPI policy) ---
ENV=production
THIRAMAI_ENV=production

# --- PostgreSQL (docker-compose service name `db`) ---
POSTGRES_USER=thiramai
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=thiramai
# Host port for web (inside container stays 8000). On some Windows hosts 8000 is reserved; use e.g. 18080.
WEB_PORT=8000

# SQLAlchemy URL inside Docker network (host `db` = Postgres service)
DATABASE_URL=postgresql+psycopg2://thiramai:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/thiramai

# --- JWT / auth (required) ---
SECRET_KEY=CHANGE_ME_MINIMUM_32_RANDOM_BYTES_USE_OPENSSL_OR_PWGEN
ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- AI providers ---
GROQ_API_KEY=your_groq_api_key
TAVILY_API_KEY=your_tavily_api_key

# --- HTTP / CORS (required in production: your real front-end / API origin URLs, HTTPS) ---
# Example: https://app.yourdomain.com,https://yourdomain.com (comma-separated, no spaces)
THIRAMAI_CORS_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# --- Security (recommended on public URLs) ---
THIRAMAI_SAFE_ERRORS=1
# Set to 1 when behind Nginx/Caddy/ALB that sets X-Forwarded-For correctly:
THIRAMAI_RL_TRUST_X_FORWARDED_FOR=1
# Trust X-Forwarded-Proto / X-Forwarded-For from reverse proxy (comma-separated IPs/CIDRs, or * for any — tighten if exposed without proxy)
THIRAMAI_PROXY_TRUSTED_HOSTS=*
# Optional: reject requests whose Host is not in this list (like Django ALLOWED_HOSTS). Leave empty to disable.
# THIRAMAI_ALLOWED_HOSTS=app.yourdomain.com,yourdomain.com,203.0.113.10,127.0.0.1,localhost
# Emergency only: serve legacy static/index.html at GET / again (default is React Command Center).
# THIRAMAI_LEGACY_ROOT_SPA=1
# JSON access-style lines to stdout (method, path, status, duration_ms, correlation_id)
THIRAMAI_LOG_JSON=1
# If 1, readiness returns 503 when GROQ_API_KEY or TAVILY_API_KEY is missing (strict chat deployments)
# THIRAMAI_HEALTH_REQUIRE_AI=0
# Optional: 1 to require Origin/Referer for mutating non-Browser-API calls
# THIRAMAI_STRICT_ORIGIN=0

# --- Rate limits (tune for launch; raise chat query limit for power users if needed) ---
THIRAMAI_RL_AUTH_PER_MINUTE=20
THIRAMAI_RL_CHAT_PER_MINUTE=40
THIRAMAI_RL_CHAT_QUERY_PER_USER_PER_MINUTE=30

# --- Dev bypass (MUST stay off in production) ---
THIRAMAI_AUTH_DISABLED=0

# --- Alerts (prod-slim: runs inside web container when THIRAMAI_ENABLE_ALERT_SCHEDULER=1) ---
THIRAMAI_ENABLE_ALERT_SCHEDULER=1
THIRAMAI_ALERT_INTERVAL_MINUTES=15
THIRAMAI_ALERT_LOW_STOCK_THRESHOLD=10

# --- Personal OS: Today / morning brief weather (Open-Meteo, no API key) ---
# Decimal degrees; leave 0 or unset to disable weather on GET /personal/os/today-brief
# PERSONAL_OS_WEATHER_LAT=12.97
# PERSONAL_OS_WEATHER_LON=77.59

# --- Autonomous AI (runs inside API process when enabled; APScheduler) ---
# THIRAMAI_ENABLE_AUTONOMY_ENGINE=1
# THIRAMAI_AUTONOMY_INTERVAL_MINUTES=15

# --- Redis (docker-compose.yml + docker-compose.production.yml) ---
REDIS_URL=redis://redis:6379/0

# --- Gunicorn (multi-worker API — set on `web` when using production Dockerfile CMD) ---
# GUNICORN_WORKERS=4

# --- PostgreSQL job queue (HITL invoices / brain intents → background_jobs) ---
# Use **db** with docker-compose.production.yml or docker-compose.yml (+ worker-jobs).
# For docker-compose.prod-slim.yml only: set **inline** or comment out (default inline).
THIRAMAI_JOB_QUEUE=db
THIRAMAI_WORKER_POLL_SEC=2

# --- Retail / GST (optional) ---
# THIRAMAI_AUTO_EXECUTE_SELL_STOCK=1
# THIRAMAI_RETAIL_SALE_ROLES=admin,staff
# THIRAMAI_RETAIL_GST_IGST=0

# --- HITL / billing ---
SOVEREIGN_BYPASS_HITL=0
