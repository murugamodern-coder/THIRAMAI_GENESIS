{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thiramai.local/schemas/autonomous_plan.schema.json",
  "title": "THIRAMAI autonomous plan",
  "type": "object",
  "required": ["goal", "strategy", "confidence", "steps"],
  "properties": {
    "goal": { "type": "string", "minLength": 1 },
    "strategy": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "required": ["id", "type", "description"],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "type": {
          "type": "string",
          "enum": ["audit", "analysis", "coding", "research", "fix", "api", "device"]
        },
        "description": { "type": "string" },
        "command": { "type": "string" },
        "expected_output_regex": { "type": "string", "description": "Optional regex matched against stdout for verification" },
        "success_criteria": { "type": "string" },
        "tier": {
          "type": "string",
          "enum": ["critical", "normal", "optional"],
          "description": "Mapped to stability scheduler: optional may skip under load"
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "high requires POST /ai/approve before execution"
        },
        "parallel_safe": { "type": "boolean", "description": "audit+single shell command only; executor may batch" },
        "retry_limit": { "type": "integer", "minimum": 0, "maximum": 5 },
        "priority": { "type": "integer", "minimum": 1, "maximum": 5 },
        "depends_on": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "description": "Step ids that must complete successfully before this step runs"
        }
      }
    }
  }
}
