# Copy to `.env` and fill with your keys. Do not commit real secrets.
#
# Phase 5 (cloud / Docker production): see `.env.production.example` and `docs/DEPLOYMENT.md`.

# --- AI providers ---
GROQ_API_KEY="your_groq_api_key"
TAVILY_API_KEY="your_tavily_api_key"
# Agentic JSON plans (Plan→Approve→Execute); default DeepSeek-R1 distill on Groq:
# THIRAMAI_AGENT_PLAN_MODEL=deepseek-r1-distill-llama-70b
# THIRAMAI_AGENT_PLAN_MODEL_FALLBACK=llama-3.3-70b-versatile
#
# Trading OS agent sizing (risk % of deployable capital — see services/agent_stock_bridge.py):
# THIRAMAI_TRADE_RISK_PERCENT=2
# THIRAMAI_TRADING_CAPITAL_INR=500000
# Optional Nifty options placeholder (until broker bridge):
# THIRAMAI_NIFTY_OPTIONS_LOT_SIZE=65
# THIRAMAI_OPTION_STRIKE_STEP=50
#
# Broker adapters (Trading OS live mode — optional pip: fyers-apiv3 / kiteconnect)
# THIRAMAI_BROKER_PROVIDER=fyers
# FYERS_CLIENT_ID=
# FYERS_SECRET_KEY=
# FYERS_ACCESS_TOKEN=
# Or Zerodha KiteConnect:
# THIRAMAI_BROKER_PROVIDER=zerodha
# KITE_API_KEY=
# KITE_API_SECRET=
# KITE_ACCESS_TOKEN=
# Agent plan trade step: force quantity to 1 share (equity) regardless of risk sizing (1/true/yes/on).
# THIRAMAI_DRY_RUN_FORCE_QTY=1
#
# Greeks / sentiment sizing (Trading OS agent)
# THIRAMAI_RISK_FREE_RATE=0.07
# THIRAMAI_IV_DEFAULT=0.18
# THIRAMAI_THETA_DECAY_RATIO_MAX=0.14
# THIRAMAI_SENTIMENT_CONTRADICTION_ABS=0.38

# Dev-only: bypass auth for local smoke tests (never enable in production).
# THIRAMAI_AUTH_DISABLED=1

# --- JWT / auth (required for production) ---
# SECRET_KEY="use-a-long-random-string-at-least-32-chars"
# ALGORITHM=HS256
# Legacy aliases: JWT_SECRET_KEY, JWT_SECRET (same as JWT_SECRET_KEY), JWT_ALGORITHM
# JWT_ACCESS_EXPIRE_MINUTES=30   # short access JWT (default if neither var set)
# JWT_EXPIRE_MINUTES=1440        # legacy: used only if JWT_ACCESS_EXPIRE_MINUTES unset
# JWT_REFRESH_EXPIRE_DAYS=30     # opaque refresh token row lifetime (POST /auth/refresh rotates)
# Optional JWT hardening (iss/aud/tv claims; decode validates when set):
# JWT_ISSUER=https://api.thiramai.example
# JWT_AUDIENCE=thiramai-clients
# JWT_TOKEN_VERSION=1

# --- Web Push (VAPID) — background notifications when PWA is closed ---
# Generate keys: python scripts/generate_thiramai_vapid_keys.py
# THIRAMAI_VAPID_PUBLIC_KEY=base64url_uncompressed_p256_public_point
# THIRAMAI_VAPID_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# THIRAMAI_VAPID_SUBJECT=mailto:ops@yourdomain.com
# UTC hour (0-23) for daily brief push window start (first 15 min of that hour). Default ~7:30 IST when 2.
# THIRAMAI_PUSH_DAILY_BRIEF_HOUR_UTC=2

# --- HTTP / CORS ---
# Comma-separated origins only — **never** use * (wildcard is disabled in all environments).
# THIRAMAI_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000
# THIRAMAI_CORS_ALLOW_ALL — deprecated; ignored for CORS (explicit dev defaults are used instead).

# --- Security middleware ---
# THIRAMAI_SAFE_ERRORS=0          # 1 = generic API error bodies (hide internals); log server-side
# THIRAMAI_STRICT_ORIGIN=0      # 1 = require Origin/Referer in THIRAMAI_CORS_ORIGINS for mutating requests without Bearer
# Behind a reverse proxy, optionally trust X-Forwarded-For for rate limits (only if the proxy strips client spoofing):
# THIRAMAI_RL_TRUST_X_FORWARDED_FOR=0

# --- Rate limits (/auth/* and GET /chat, per client IP) ---
# THIRAMAI_RL_AUTH_PER_MINUTE=20
# THIRAMAI_RL_CHAT_PER_MINUTE=40
# POST /chat/query: per JWT user (sub), after exp/signature check (default 5/min for abuse testing)
# THIRAMAI_RL_CHAT_QUERY_PER_USER_PER_MINUTE=5
#
# Redis global cap (horizontal replicas): per JWT user or per IP; exempt /auth/*, /health*, /docs*, /static/*
# THIRAMAI_RL_GLOBAL_PER_MINUTE=100
# THIRAMAI_RL_REDIS_GLOBAL=1     # set 0 to disable even if REDIS_URL is set
#
# Dashboard / Life OS snapshot cache (Redis JSON, default TTL 300s)
# THIRAMAI_SNAPSHOT_CACHE_TTL_SEC=300

# --- Environment label (production safety) ---
# ENV=development
# THIRAMAI_ENV=development
# If ENV or THIRAMAI_ENV is "production": THIRAMAI_AUTH_DISABLED aborts startup; THIRAMAI_SAFE_ERRORS must be truthy;
# THIRAMAI_CORS_ORIGINS must be a non-empty explicit list (no *); Swagger/Redoc UIs are disabled; CORS allow-all is ignored.

# --- Dev bypass (never enable in production) ---
# THIRAMAI_AUTH_DISABLED=0
# THIRAMAI_DEV_ORG_ID=1

# --- Tenant defaults (CLI brain.py, legacy index rows) ---
# THIRAMAI_DEFAULT_ORG_ID=1

# --- Docker Compose (see docker-compose.yml) ---
# POSTGRES_USER=thiramai
# POSTGRES_PASSWORD=change_me_strong
# POSTGRES_DB=thiramai
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# WEB_PORT=8000
# DATABASE_URL=postgresql+psycopg2://thiramai:change_me_strong@db:5432/thiramai
# REDIS_URL=redis://redis:6379/0

# --- Schema discipline (production) ---
# ENV=production or THIRAMAI_DISABLE_CREATE_ALL=1 → SRE health check will not run create_all; use Alembic.
# THIRAMAI_DISABLE_CREATE_ALL=1
#
# Alembic: alembic upgrade head  (baseline revision 0001 applies db/*.sql order in core/migration_sql.py)
#
# Readiness: optional worker heartbeats (Redis). Example full stack:
# THIRAMAI_HEALTH_EXPECT_WORKERS=job_worker,alert_worker
# THIRAMAI_HEARTBEAT_TTL_SEC=120
# Skip Alembic row check in dev only:
# THIRAMAI_SKIP_ALEMBIC_CHECK=1

# --- PostgreSQL (structured vault, auth, audits, HITL) ---
# Apply SQL in order: db/db_schema.sql (includes idempotency_keys + background_jobs), db/auth_rbac.sql,
# db/approvals_table.sql, db/notifications_alerts.sql, db/learning_logs.sql, db/system_audit_logs.sql,
# db/bills_table.sql (as needed). Existing DBs: also run db/idempotency_and_jobs.sql once.
# Factory OS: db/factory_os.sql (project_stages, project_staff_assignments, factory_billing_hold).
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/thiramai

# --- Multi-agent layer (orchestrator brain extension; default off) ---
# When 1, each ``run_orchestrator_brain`` also runs manager agents + workers (audit + optional tools).
# THIRAMAI_MULTI_AGENT=0
# Or per-request: pass context include_multi_agent=true from trusted callers only.

# --- Autonomous AI loop (optional worker; NOT started by FastAPI) ---
# Master switch: without this, ``python -m core.autonomous_scheduler`` exits immediately (no loop).
# THIRAMAI_AUTONOMOUS_MODE=0
# Org(s) to scan each tick (comma-separated or single id):
# THIRAMAI_AUTONOMOUS_ORG_ID=1
# THIRAMAI_AUTONOMOUS_ORG_IDS=1,2
# Sleep between full multi-org passes (seconds, min 15):
# THIRAMAI_AUTONOMOUS_INTERVAL_SEC=60
# When true, safe tool intents (read_inventory, add_inventory) run via policy-aware execute_intent.
# THIRAMAI_AUTONOMOUS_EXEC=0
# Also honors THIRAMAI_ORCHESTRATOR_AUTO_MODE if THIRAMAI_AUTONOMOUS_EXEC is unset/off.
# Optional principal for tool audit: THIRAMAI_AUTONOMOUS_ACTOR_ROLE=owner
# THIRAMAI_AUTONOMOUS_USER_ID=
# THIRAMAI_AUTONOMOUS_ROLE_LEVEL=
# UTC hour (0-23) before ``no_sales`` heuristic fires (default 12).
# THIRAMAI_AUTONOMOUS_NO_SALES_MIN_HOUR_UTC=12

# --- Alert scheduler (APScheduler) ---
# THIRAMAI_ENABLE_ALERT_SCHEDULER=0
# THIRAMAI_ALERT_INTERVAL_MINUTES=15
# THIRAMAI_ALERT_LOW_STOCK_THRESHOLD=10
# THIRAMAI_ALERT_ORG_IDS=1,2
#
# JARVIS Eye — IMAP poll → emergency tax/business email → in-app notification (kind jarvis_email_emergency).
# Requires PostgreSQL notifications table + THIRAMAI_ENABLE_ALERT_SCHEDULER=1 (or run python -m workers.alert_system).
# THIRAMAI_JARVIS_EMAIL_POLL=0
# THIRAMAI_JARVIS_EMAIL_INTERVAL_MINUTES=60
# THIRAMAI_JARVIS_ORG_ID=1
# THIRAMAI_JARVIS_EMAIL_MAX_FETCH=30
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_USER=you@gmail.com
# EMAIL_IMAP_PASSWORD=app-password
# EMAIL_IMAP_MAILBOX=INBOX
# EMAIL_IMAP_USE_SSL=1
#
# Phase 5 Compliance & Comms: optional JSON override for statutory due-day templates (see compliance_service).
# THIRAMAI_STATUTORY_RULES_JSON=[{"key":"gstr1","label":"GSTR-1","day_of_month":11,"category":"GST"}]

# --- Background jobs (API vs worker process) ---
# THIRAMAI_JOB_QUEUE=inline   # default: FastAPI BackgroundTasks in the API process
# THIRAMAI_JOB_QUEUE=db       # enqueue to PostgreSQL background_jobs; run: python -m workers.run_worker
# THIRAMAI_WORKER_POLL_SEC=2
# In-flight idempotency rows older than this (minutes) may be reclaimed after a crash:
# THIRAMAI_IDEMPOTENCY_STALE_MINUTES=120

# --- HITL billing (dev only) ---
# SOVEREIGN_BYPASS_HITL=0

# --- Retail sell_stock (Phase 1) ---
# 1 = after brain detects sell_stock (or heuristic), deduct inventory + insert bills row (default).
# 0 = intent only in narrative; use HITL approvals to execute sell_stock.
# THIRAMAI_AUTO_EXECUTE_SELL_STOCK=1
# Comma-separated role names allowed to auto-execute retail sales (default: admin,staff).
# THIRAMAI_RETAIL_SALE_ROLES=admin,staff
# Dev-only: THIRAMAI_RETAIL_SALE_ROLES=admin,staff,owner
# Inter-state retail bills: charge full rate as IGST (else CGST+SGST split). Default off.
# THIRAMAI_RETAIL_GST_IGST=0

# --- Business dashboard (Phase 5): low-stock threshold for GET /dashboard/* and AI snapshot ---
# THIRAMAI_DASHBOARD_LOW_STOCK_THRESHOLD=5
# Daily sales target (INR, bills) for Business OS snapshot vs actual — optional.
# THIRAMAI_DAILY_SALES_TARGET_INR=100000

# --- AI orchestrator: routine brief (command center / sales snapshot / simple sell) without council ---
# 1 = short **Action Completed:** responses when the message matches routine triggers (default).
# 0 = always run full Groq/Tavily/council pipeline (keys still required).
# THIRAMAI_ROUTINE_BRIEF=1

# --- QA stress (optional PostgreSQL only; see tests/test_stress_concurrent_sells.py) ---
# THIRAMAI_STRESS_DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/stress_empty_db

# --- Phase 4 seed (scripts/seed_real_data.py) ---
# THIRAMAI_SEED_ORG_ID=1
# Apply db/inventory_gst_columns.sql and db/inventory_hsn_code.sql on PostgreSQL if columns are missing.
# Life OS (daily_planner, health_logs, personal_reminders, user_personal_crypto): db/life_os.sql
# Server-side Fernet for migrating plaintext notes from vault JSON into ``enc_notes`` (PBKDF2 + fixed app salt).
# Min 8 characters. Distinct from per-user ``X-Personal-Vault-Passphrase`` / ``user_personal_crypto``.
# VAULT_PASSPHRASE="long-random-server-secret-here"

# --- User runtime vault (PostgreSQL ``user_runtime_config``): broker keys encrypted at rest ---
# Required in production/staging if users save FYERS/KITE credentials via the API.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# THIRAMAI_VAULT_FERNET_KEY=
# Alias supported: FERNET_KEY=
# Optional dev mirror to repo-root .env.local (never enabled when ENV or THIRAMAI_ENV=production):
# THIRAMAI_MIRROR_CONFIG_TO_ENV_LOCAL=1

# --- Optional integrations (do not commit real tokens) ---
# WHATSAPP_ALERT_TO=+9198xxxxxxx
# EMAIL_ACCESS_TOKEN=
# EMAIL_IMAP_HOST=
# BLENDER_EXECUTABLE=
# ROBOTICS_BLENDER_SCRIPT=
# ONSHAPE_ACCESS_KEY=
# ONSHAPE_SECRET_KEY=
# ONSHAPE_DOCUMENT_ID=

# --- Unified local AI (Ollama) + background agent ---
# Ollama HTTP API (default http://127.0.0.1:11434)
# OLLAMA_HOST=http://127.0.0.1:11434
# THIRAMAI_LOCAL_AI_ENABLED=1          # set 0 to disable POST /ai/local/*
# THIRAMAI_OLLAMA_MODEL_SHORT=llama3
# THIRAMAI_OLLAMA_MODEL_REASONING=deepseek-r1:8b
# THIRAMAI_OLLAMA_MODEL_LONG=gemma2:9b
# THIRAMAI_ROUTER_LONG_CHARS=900       # messages longer than this → long-output model
#
# Background suggestion loop → thought stream (opt-in)
# THIRAMAI_BACKGROUND_AGENT=1
# THIRAMAI_BACKGROUND_USER_ID=1
# THIRAMAI_BACKGROUND_ORG_ID=1
# THIRAMAI_BACKGROUND_AGENT_INTERVAL=60
# THIRAMAI_BACKGROUND_LOW_STOCK=5

# --- Safe startup (`python run_system.py` — preflight, optional npm rebuild, then uvicorn) ---
# THIRAMAI_STARTUP_REQUIRED_ENV=DATABASE_URL,SECRET_KEY   # comma-separated; all must be non-empty
# THIRAMAI_STARTUP_PROBE_API=1                           # require /health/live + /health/ready before bind
# THIRAMAI_STARTUP_API_BASE=http://127.0.0.1:8000       # base URL for API probe
# THIRAMAI_STARTUP_AUTO_BUILD=0                         # 0 = never run npm rebuild from auto-fix
# THIRAMAI_STARTUP_BUILD_TIMEOUT_SEC=300
# THIRAMAI_STARTUP_FIX_ROUNDS=2
# THIRAMAI_STARTUP_HEALTH_RETRIES=3
# THIRAMAI_STARTUP_HEALTH_TIMEOUT_SEC=3
# THIRAMAI_STARTUP_RESTART_ON_API_FAIL=0                # 1 = run THIRAMAI_STARTUP_RESTART_CMD on API probe fail
# THIRAMAI_STARTUP_RESTART_CMD=                         # shell one-liner (supervisor / systemd hook)
# THIRAMAI_STARTUP_DISABLE_POST_PROBE=1               # skip non-blocking /health/live self-probe after bind
# THIRAMAI_STARTUP_POST_PROBE_DELAY_SEC=0.8
# THIRAMAI_STARTUP_EXIT_IF_HEALTHY_PORT=1             # if port open + healthy, exit 0 without second server
# THIRAMAI_INCIDENT_MODE=1                            # disable heavy background work (also set by run_system on failure)
# THIRAMAI_STARTUP_DEGRADED=1                         # same as incident for scheduler gating
# THIRAMAI_AUTO_FIX_MAX_PER_ISSUE=3                   # cap npm rebuild / restart attempts per failing check
# THIRAMAI_AUTO_FIX_COOLDOWN_SEC=2                    # sleep between auto-fix rounds in run_system.py

# --- Runtime stability (circuit breaker, backoff, resource hints; optional `pip install psutil`) ---
# THIRAMAI_STABILITY_CB_FAILURE_THRESHOLD=5           # consecutive HTTP failures before circuit opens
# THIRAMAI_STABILITY_CB_COOLDOWN_SEC=60               # pause API calls while circuit open
# THIRAMAI_STABILITY_RETRY_BASE_SEC=0.15
# THIRAMAI_STABILITY_RETRY_MAX_SEC=8
# THIRAMAI_STABILITY_RETRY_JITTER=0.25
# THIRAMAI_STABILITY_FAILURE_REPEAT_THRESHOLD=5       # failure memory: degrade / skip after repeats
# THIRAMAI_STABILITY_ESCALATE_AFTER_FAILURES=8        # auto incident mode when failure count high
# THIRAMAI_STABILITY_CPU_PERCENT=90                   # optional overload hint (requires psutil)
# THIRAMAI_STABILITY_MEMORY_MB=                      # optional RSS cap hint (MB)
# THIRAMAI_STABILITY_THREAD_THRESHOLD=               # optional thread count cap
# THIRAMAI_STABILITY_RESOURCE_POLL_SEC=0             # >0 and psutil: periodic [RESOURCE LIMIT] log
# THIRAMAI_STABILITY_RUN_OPTIONAL_WHEN_OVERLOADED=0  # defer optional tasks when overloaded

# --- Standalone autonomous package (`python thiramai/main.py`, repo `thiramai/`) ---
# OPENAI_API_KEY=sk-...                 # required only for THIRAMAI_MODE=live
# THIRAMAI_MODE=simulation              # dry-run | simulation | live (live without key → dry-run)
# THIRAMAI_DYNAMIC_GOALS=0              # 1 = sovereign goal queue each cycle (uses LLM in live/simulation)
# THIRAMAI_MAX_LOOP_ITERATIONS=0        # 0 = unlimited; else exit after N cycles
# THIRAMAI_MAX_CONSECUTIVE_CYCLE_FAILURES=5
# THIRAMAI_LOOP_SLEEP_SEC=30
